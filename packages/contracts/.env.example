# デプロイヤーの秘密鍵（0x プレフィックスなし）
DEPLOYER_PRIVATE_KEY=

# RPC エンドポイント（省略時はパブリックノードを使用）
AMOY_RPC_URL=https://rpc-amoy.polygon.technology
POLYGON_RPC_URL=https://polygon-rpc.com

# Polygonscan API キー（コントラクト検証用）
POLYGONSCAN_API_KEY=

# デプロイ時に使用するアドレス
# プラットフォーム手数料受取アドレス（ComputeMarket）
PLATFORM_FEE_RECIPIENT=

# JPYC トークンアドレス
# Amoy テストネット用 MockERC20 デプロイ後に設定
# mainnet: 0x431D5dfF03120AFA4bDf332c61A6e1766eF37BF6（Polygon JPYC v2）
JPYC_TOKEN_ADDRESS=
