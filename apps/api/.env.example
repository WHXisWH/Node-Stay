PORT=3001

# CORS（カンマ区切り）
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# データベース
DATABASE_URL=postgresql://nodestay:nodestay@localhost:5432/nodestay
REDIS_URL=redis://localhost:6379

# 認証
JWT_SECRET=

# フィーチャーフラグ
ENABLE_COMPUTE_MARKET=true
ENABLE_TRANSFER_MARKET=false

# Polygon Amoy テストネット コントラクトアドレス
MACHINE_REGISTRY_ADDRESS=
USAGE_RIGHT_ADDRESS=
SETTLEMENT_ADDRESS=
MARKETPLACE_ADDRESS=
COMPUTE_RIGHT_ADDRESS=
REVENUE_RIGHT_ADDRESS=

# オペレータ秘密鍵（バックエンドがコントラクトを呼び出す場合）
OPERATOR_PRIVATE_KEY=

# RPC エンドポイント
AMOY_RPC_URL=https://rpc-amoy.polygon.technology
