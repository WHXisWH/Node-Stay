{
  "name": "@nodestay/api",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "node --require reflect-metadata -r @swc-node/register --watch src/main.ts",
    "dev:workers": "npm run worker:compute-scheduler & npm run worker:revenue-allocation",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "worker:compute-scheduler": "tsx src/workers/compute-scheduler.ts",
    "worker:revenue-allocation": "tsx src/workers/revenue-allocation-scheduler.ts",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "lint": "echo \"(skip)\"",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.8",
    "@nestjs/core": "^10.4.8",
    "@nestjs/platform-express": "^10.4.8",
    "@nodestay/api-contracts": "0.0.1",
    "@nodestay/domain": "0.0.1",
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "dotenv": "^17.3.1",
    "ethers": "^6.16.0",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.20.0",
    "prisma": "^7.4.2",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "siwe": "^3.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@nestjs/testing": "^10.4.8",
    "@swc-node/register": "^1.11.1",
    "@swc/core": "^1.15.18",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.17.17",
    "@types/supertest": "^6.0.2",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-node-dev": "^2.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.6.3"
  }
}
